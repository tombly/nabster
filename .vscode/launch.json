{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Report: Historical",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "report",
                "historical"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Report: Planning",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "report",
                "planning",
                "--output-format",
                "html"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Report: Spend",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "report",
                "spend",
                "--category-name",
                "Discretionary",
                "--month",
                "2026-04"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Report: Daily",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "report",
                "daily",
                "--category-names",
                "Discretionary",
                "Groceries",
                "Unplanned"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Report: Daily (server)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "report",
                "daily",
                "--url",
                "http://localhost:7071/api/IncomingMessage"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Utility: Memo",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (cli)",
            "program": "${workspaceFolder}/Nabster.Cli/bin/Debug/net10.0/Nabster.Cli.dll",
            "args": [
                "utility",
                "memo",
                "--since-date",
                "2022-04-01"
            ],
            "cwd": "${workspaceFolder}/Nabster.Cli",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Local Server",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:azureFunctions.pickProcess}"
        }
    ]
}